---
import { clinicConfig } from '../config.js';

const { config = clinicConfig } = Astro.props;
const { features, featuresHeading } = config;

const iconPaths = {
  UserCheck: 'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z',
  Cpu: 'M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18',
  ShieldCheck: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
};
---

<section class="pt-16 pb-36 md:pb-44 bg-gradient-to-r from-brand-light/30 to-white border-y border-brand-primary/5 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20">

    <!-- Section Heading -->
    <div class="features-heading section-heading text-center max-w-2xl mx-auto mb-16 relative">
      <div class="absolute top-[10%] left-[50%] -translate-x-[50%] w-72 h-72 rounded-full -z-10 pointer-events-none" style="background: radial-gradient(ellipse at center, var(--color-primary) 0%, transparent 70%); opacity: 0.12;" />
      <span class="text-xs font-bold text-brand-primary uppercase tracking-widest bg-brand-primary/10 px-4 py-1.5 rounded-full mb-3.5 inline-block">
        {featuresHeading?.title || 'Neden Kliniğimiz?'}
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-dark tracking-tight font-display">
        {featuresHeading?.subtitle || 'Diş Kliniğimizin Farkı'}
      </h2>
      <div class="w-14 h-1 bg-brand-primary mx-auto mt-3 rounded-full shadow-sm"></div>
      <p class="mt-4 text-brand-muted text-sm sm:text-base leading-relaxed">
        {featuresHeading?.description || 'Kliniğimizde her detayı konforunuz, güvenliğiniz ve en yüksek tedavi başarısı için tasarladık.'}
      </p>
    </div>

    <!-- Feature Cards Grid -->
    <div class="features-grid grid md:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="feature-card p-8 rounded-3xl bg-white/80 border border-white/60 text-left shadow-[0_15px_40px_rgba(0,0,0,0.03)] hover:shadow-[0_25px_50px_rgba(0,0,0,0.09)] hover:border-brand-primary/25 hover:bg-white transform hover:-translate-y-2.5 transition-all duration-500 group h-full relative overflow-hidden">

          <!-- Decorative corner -->
          <div class="absolute bottom-0 right-0 w-24 h-24 bg-gradient-to-br from-brand-primary/0 to-brand-primary/5 rounded-tl-[100px] pointer-events-none group-hover:scale-110 transition-transform duration-500" />

          <!-- Icon Frame -->
          <div class="w-14 h-14 rounded-2xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mb-6 group-hover:bg-brand-primary group-hover:text-white transition-all duration-500 group-hover:scale-105">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d={iconPaths[feature.icon] || iconPaths.ShieldCheck} />
            </svg>
          </div>

          <!-- Title & Description -->
          <h3 class="text-xl font-bold text-brand-dark font-display mb-3">{feature.title}</h3>
          <p class="text-sm text-brand-muted leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

  </div>

  <!-- Wave Divider -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-none">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full" style="height: clamp(80px, 9vw, 140px);" aria-hidden="true">
      <path d="M0,60 C240,100 480,20 720,60 C960,100 1200,20 1440,60 L1440,120 L0,120 Z" class="fill-white" />
    </svg>
  </div>
</section>

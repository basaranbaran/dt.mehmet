---
import { clinicConfig } from '../config.js';

const { brand, contact, socials } = clinicConfig;

const navLinks = [
  { name: 'Anasayfa', href: '#anasayfa' },
  { name: 'Hakkımızda', href: '#hakkimizda' },
  { name: 'Tedaviler', href: '#tedaviler' },
  { name: 'Kliniğimiz', href: '#galeri' },
  { name: 'İletişim', href: '#iletisim' },
];

const socialIconPaths = {
  facebook: 'M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z',
  instagram: 'M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zM17.5 6.5h.01',
  twitter: 'M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z',
  youtube: 'M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z M9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02z',
};

const year = new Date().getFullYear();
---

<footer class="bg-brand-dark text-white pt-16 pb-8 relative">

  <!-- Scroll to Top Button -->
  <button
    id="scroll-to-top"
    class="absolute top-[-24px] left-1/2 transform -translate-x-1/2 w-12 h-12 rounded-full bg-[#B3D9FF] hover:bg-[#99ccff] text-brand-dark hover:text-brand-dark shadow-xl flex items-center justify-center border-4 border-brand-dark transition-colors cursor-pointer"
    aria-label="Sayfanın Başına Git"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
    </svg>
  </button>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-12 text-left border-b border-gray-800 pb-12">

      <!-- Logo & Slogan -->
      <div class="footer-col space-y-4">
        <div class="flex flex-col">
          <span class="text-2xl font-bold tracking-wider uppercase font-display text-brand-accent">
            {brand.logoText}
          </span>
          <span class="text-[10px] tracking-widest uppercase font-medium text-gray-400 -mt-1">
            {brand.logoSubtext}
          </span>
        </div>
        <p class="text-sm text-gray-400 max-w-sm leading-relaxed">
          Alsancak'ta modern teknolojiler, tecrübeli hekim kadrosu ve üstün hijyen standartlarıyla ağız ve diş sağlığınız için en iyi çözümleri üretiyoruz.
        </p>
      </div>

      <!-- Hızlı Erişim -->
      <div class="footer-col space-y-4">
        <h4 class="text-base font-bold uppercase tracking-wider font-display text-white">Hızlı Erişim</h4>
        <div class="grid grid-cols-2 gap-2 text-sm text-gray-400">
          {navLinks.map((link) => (
            <a href={link.href} class="footer-nav-link hover:text-brand-accent transition-colors py-1">{link.name}</a>
          ))}
        </div>
      </div>

      <!-- Sosyal Medya -->
      <div class="footer-col space-y-4">
        <h4 class="text-base font-bold uppercase tracking-wider font-display text-white">Bizi Takip Edin</h4>
        <div class="flex space-x-4">
          {Object.entries(socials).map(([key, url]) => url && (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="p-3 bg-gray-900 hover:bg-brand-accent text-gray-400 hover:text-white rounded-xl shadow-inner transition-all transform hover:-translate-y-0.5"
              aria-label={`Bizi ${key}'de takip edin`}
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                {key === 'instagram' && (
                  <>
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" />
                    <path d={socialIconPaths.instagram} />
                    <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                  </>
                )}
                {key !== 'instagram' && <path d={socialIconPaths[key] || ''} />}
              </svg>
            </a>
          ))}
        </div>
        <p class="text-xs text-gray-500 pt-2 leading-relaxed">
          Sosyal medya hesaplarımız üzerinden güncel vaka görsellerini ve diş sağlığı ipuçlarını takip edebilirsiniz.
        </p>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="pt-8 text-center text-xs text-gray-500 border-t border-gray-800/50 mt-4">
      <p>© {year} {brand.name} Diş Polikliniği. Tüm Hakları Saklıdır.</p>
    </div>
  </div>
</footer>

<script>
  // Scroll to top
  document.getElementById('scroll-to-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Footer nav smooth scroll
  document.querySelectorAll('.footer-nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (href?.startsWith('#')) {
        e.preventDefault();
        const id = href.replace('#', '');
        const el = document.getElementById(id);
        if (el) {
          const top = el.getBoundingClientRect().top + window.scrollY - 60;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      }
    });
  });
</script>

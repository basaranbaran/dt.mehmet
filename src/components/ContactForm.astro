---
import { clinicConfig } from '../config.js';

const { contact, brand } = clinicConfig;
---

<section id="iletisim" class="py-20 bg-brand-light relative overflow-hidden">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Başlık -->
    <div class="section-heading text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-bold text-brand-primary uppercase tracking-widest font-display">
        İletişim
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-dark tracking-tight font-display mt-2">
        İletişim Bilgilerimiz
      </h2>
      <div class="w-12 h-1 bg-brand-primary mx-auto mt-4 rounded-full"></div>
      <p class="mt-4 text-brand-muted text-sm sm:text-base">
        Bize çalışma saatleri içerisinde telefon veya e-posta ile ulaşabilirsiniz.
      </p>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 items-stretch">

      <!-- Sol: İletişim Bilgileri -->
      <div class="contact-info-col lg:col-span-5 text-left flex flex-col justify-center space-y-4">
        <h3 class="text-2xl font-bold text-brand-dark font-display mb-2">Klinik İletişim Detayları</h3>

        <!-- Telefon -->
        <a
          href={`tel:${contact.phoneClean}`}
          class="flex items-start space-x-4 p-5 rounded-2xl bg-brand-light/20 border border-brand-primary/10 hover:border-brand-primary/30 transition-all hover:shadow-md group"
        >
          <div class="p-3 bg-white rounded-xl text-brand-primary shadow-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider">Telefon</h4>
            <p class="text-base font-bold text-brand-dark mt-0.5 group-hover:text-brand-primary transition-colors">{contact.phone}</p>
          </div>
        </a>

        <!-- E-Posta -->
        <a
          href={`mailto:${contact.email}`}
          class="flex items-start space-x-4 p-5 rounded-2xl bg-brand-light/20 border border-brand-primary/10 hover:border-brand-primary/30 transition-all hover:shadow-md group"
        >
          <div class="p-3 bg-white rounded-xl text-brand-primary shadow-sm">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider">E-Posta</h4>
            <p class="text-base font-bold text-brand-dark mt-0.5 group-hover:text-brand-primary transition-colors">{contact.email}</p>
          </div>
        </a>

        <!-- Adres -->
        <div class="flex items-start space-x-4 p-5 rounded-2xl bg-brand-light/20 border border-brand-primary/10">
          <div class="p-3 bg-white rounded-xl text-brand-primary shadow-sm shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider">Adres</h4>
            <p class="text-sm font-semibold text-brand-dark mt-0.5 leading-relaxed">{contact.address}</p>
          </div>
        </div>

        <!-- Çalışma Saatleri -->
        <div class="flex items-start space-x-4 p-5 rounded-2xl bg-brand-light/20 border border-brand-primary/10">
          <div class="p-3 bg-white rounded-xl text-brand-primary shadow-sm shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="w-full">
            <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider mb-2">Çalışma Saatleri</h4>
            <div class="space-y-1.5">
              {contact.workingHours.map((item) => (
                <div class="flex justify-between text-xs sm:text-sm font-medium text-brand-dark">
                  <span class="text-brand-muted">{item.days}</span>
                  <span class="font-bold">{item.hours}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Sağ: Google Harita -->
      <div class="contact-map-col lg:col-span-7 h-[400px] lg:h-auto min-h-[400px]">
        <div class="rounded-3xl overflow-hidden shadow-lg border border-brand-primary/10 h-full w-full relative min-h-[400px]">
          <iframe
            title="Klinik Harita Konumu"
            src={contact.googleMapsEmbedUrl}
            class="absolute inset-0 w-full h-full border-0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

    </div>
  </div>
</section>

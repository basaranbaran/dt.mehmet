---
import { clinicConfig } from '../config.js';

const { config = clinicConfig } = Astro.props;
const { contact, contactHeading } = config;
---

<section id="iletisim" class="py-20 bg-brand-light relative overflow-hidden">

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Başlık -->
    <div class="section-heading text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-bold text-brand-primary uppercase tracking-widest font-display">
        {contactHeading?.title || 'İletişim'}
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-brand-dark tracking-tight font-display mt-2">
        {contactHeading?.subtitle || 'İletişim ve Randevu'}
      </h2>
      <div class="w-12 h-1 bg-brand-primary mx-auto mt-4 rounded-full"></div>
      <p class="mt-4 text-brand-muted text-sm sm:text-base">
        {contactHeading?.description || 'Çalışma saatleri içerisinde bize ulaşabilir veya hızlıca mesajınızı iletebilirsiniz.'}
      </p>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 items-stretch">

      <!-- Sol: İletişim Bilgileri & Harita -->
      <div class="contact-info-col lg:col-span-5 text-left flex flex-col space-y-6">
        <div class="space-y-4">
          <h3 class="text-2xl font-bold text-brand-dark font-display mb-2">{contactHeading?.infoTitle || 'Klinik Detayları'}</h3>

          <!-- Telefon -->
          <a
            href={`tel:${contact.phoneClean}`}
            class="flex items-start space-x-4 p-4 rounded-2xl bg-white border border-brand-primary/10 hover:border-brand-primary/30 transition-all hover:shadow-md group"
          >
            <div class="p-3 bg-brand-light rounded-xl text-brand-primary shadow-sm shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider">Telefon</h4>
              <p class="text-sm font-bold text-brand-dark mt-0.5 group-hover:text-brand-primary transition-colors">{contact.phone}</p>
            </div>
          </a>

          <!-- E-Posta -->
          <a
            href={`mailto:${contact.email}`}
            class="flex items-start space-x-4 p-4 rounded-2xl bg-white border border-brand-primary/10 hover:border-brand-primary/30 transition-all hover:shadow-md group"
          >
            <div class="p-3 bg-brand-light rounded-xl text-brand-primary shadow-sm shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider">E-Posta</h4>
              <p class="text-sm font-bold text-brand-dark mt-0.5 group-hover:text-brand-primary transition-colors">{contact.email}</p>
            </div>
          </a>

          <!-- Adres -->
          <div class="flex items-start space-x-4 p-4 rounded-2xl bg-white border border-brand-primary/10">
            <div class="p-3 bg-brand-light rounded-xl text-brand-primary shadow-sm shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider">Adres</h4>
              <p class="text-xs font-semibold text-brand-dark mt-0.5 leading-relaxed">{contact.address}</p>
            </div>
          </div>

          <!-- Çalışma Saatleri -->
          <div class="flex items-start space-x-4 p-4 rounded-2xl bg-white border border-brand-primary/10">
            <div class="p-3 bg-brand-light rounded-xl text-brand-primary shadow-sm shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <div class="w-full">
              <h4 class="text-xs font-bold text-brand-secondary uppercase tracking-wider mb-2">Çalışma Saatleri</h4>
              <div class="space-y-1.5">
                {contact.workingHours.map((item) => (
                  <div class="flex justify-between text-xs font-medium text-brand-dark">
                    <span class="text-brand-muted">{item.days}</span>
                    <span class="font-bold">{item.hours}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Google Harita -->
        <div class="rounded-3xl overflow-hidden shadow-lg border border-brand-primary/10 h-[280px] w-full relative min-h-[280px] shrink-0">
          <iframe
            title="Klinik Harita Konumu"
            src={contact.googleMapsEmbedUrl}
            class="absolute inset-0 w-full h-full border-0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>

      <!-- Sağ: İletişim Formu -->
      <div class="contact-form-col lg:col-span-7 bg-white rounded-3xl p-6 sm:p-8 shadow-xl border border-gray-100 flex flex-col justify-center">
        <h3 class="text-2xl font-bold text-brand-dark font-display mb-6">{contactHeading?.formTitle || 'Bize Mesaj Gönderin'}</h3>
        <form id="contact-form-element" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="form-name" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-2">Adınız Soyadınız</label>
              <input type="text" id="form-name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all text-sm" placeholder="Örn: Ahmet Yılmaz" />
            </div>
            <div>
              <label for="form-phone" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-2">Telefon Numaranız</label>
              <input type="tel" id="form-phone" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all text-sm" placeholder="Örn: 0555 555 55 55" />
            </div>
          </div>
          <div>
            <label for="form-email" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-2">E-Posta Adresiniz</label>
            <input type="email" id="form-email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all text-sm" placeholder="Örn: ahmet@example.com" />
          </div>
          <div>
            <label for="form-message" class="block text-xs font-bold text-brand-dark uppercase tracking-wider mb-2">Mesajınız</label>
            <textarea id="form-message" rows="4" required class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 outline-none transition-all text-sm resize-none" placeholder="Sorunuzu veya talebinizi buraya yazın..."></textarea>
          </div>
          <button type="submit" class="w-full bg-brand-primary hover:bg-brand-secondary text-white font-bold py-3.5 px-6 rounded-xl shadow-lg transform hover:-translate-y-0.5 transition-all text-sm font-display flex items-center justify-center space-x-2">
            <span>Mesajı Gönder</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
            </svg>
          </button>
        </form>

        <div id="form-success-message" class="hidden mt-4 p-4 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-xl text-sm font-semibold flex items-center space-x-2">
          <svg class="w-5 h-5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>Mesajınız başarıyla iletildi. En kısa sürede sizinle iletişime geçeceğiz.</span>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form-element') as HTMLFormElement;
  const successMsg = document.getElementById('form-success-message');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (successMsg) {
      successMsg.classList.remove('hidden');
      form.reset();
      
      setTimeout(() => {
        successMsg.classList.add('hidden');
      }, 5000);
    }
  });
</script>
